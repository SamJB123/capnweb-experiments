{
  "name": "capnweb-hibernation-test-worker",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-09",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "name": "HIB_RPC",
        "class_name": "HibRpcDo"
      },
      {
        "name": "CHAT_ROOM",
        "class_name": "ChatRoomDo"
      },
      {
        "name": "NO_STORE_HIB_RPC",
        "class_name": "NoStoreHibRpcDo"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v2",
      "new_sqlite_classes": ["HibRpcDo", "ChatRoomDo"]
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["NoStoreHibRpcDo"]
    }
  ]
}
